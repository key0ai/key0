{
	"$schema": "https://mintlify.com/schema.json",
	"name": "Key0",
	"logo": {
		"dark": "/images/logo-dark.png",
		"light": "/images/logo-light.png"
	},
	"favicon": "/images/favicon.svg",
	"colors": {
		"primary": "#1a1a1a",
		"light": "#E8E8E8",
		"dark": "#1a1a1a",
		"anchors": {
			"from": "#1a1a1a",
			"to": "#525252"
		},
		"background": {
			"light": "#E8E8E8",
			"dark": "#1a1a1a"
		}
	},
	"font": {
		"headings": {
			"family": "Plus Jakarta Sans",
			"weight": 700
		},
		"body": {
			"family": "DM Sans",
			"weight": 400
		}
	},
	"modeToggle": {
		"default": "light"
	},
	"css": "/custom.css",
	"rounded": "default",
	"topbarLinks": [
