			"name": "SDK Reference",
			"url": "sdk-reference"
		},
		{
			"name": "API Reference",
			"url": "api-reference"
		},
		{
			"name": "Examples",
			"url": "examples"
		}
	],
	"anchors": [
		{
			"name": "NPM Package",
			"icon": "npm",
			"url": "https://www.npmjs.com/package/@key0ai/key0"
		},
		{
			"name": "Docker Hub",
			"icon": "docker",
			"url": "https://hub.docker.com/r/key0ai/key0"
		}
	],
