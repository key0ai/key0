# Seller agent URL (start the express-seller or hono-seller example first)
SELLER_URL=http://localhost:3000

# Your wallet private key (0x-prefixed, 64 hex chars)
# This wallet needs testnet USDC on Base Sepolia
# Get testnet USDC from: https://faucet.circle.com/
WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# Network: "testnet" (Base Sepolia) or "mainnet" (Base)
# WARNING: mainnet uses REAL USDC — use testnet for development
KEY0_NETWORK=testnet
