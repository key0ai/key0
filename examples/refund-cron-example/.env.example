# Network: "testnet" (Base Sepolia) or "mainnet" (Base)
AGENTGATE_NETWORK=testnet

# Seller wallet address — receives payments (receive-only, no private key needed here)
AGENTGATE_WALLET_ADDRESS=0xYourWalletAddressHere

# Secret for signing access tokens (min 32 chars)
AGENTGATE_ACCESS_TOKEN_SECRET=change-me-to-a-random-string-at-least-32-chars

# Wallet private key — used by the refund cron to send USDC back to payers.
# This must be the private key that corresponds to AGENTGATE_WALLET_ADDRESS.
# The wallet needs a small ETH balance on Base Sepolia for gas (~$0.001 per refund tx).
AGENTGATE_WALLET_PRIVATE_KEY=0xYourWalletPrivateKeyHere

# Optional: override the default RPC URL
# AGENTGATE_RPC_URL=https://sepolia.base.org

# Redis URL (required — used for challenge store and refund cron queue)
REDIS_URL=redis://localhost:6379

# Server port
PORT=3000

# ── Refund cron tuning ──────────────────────────────────────────────────────
# These are intentionally short for local testing so you can watch state
# transitions without waiting. In production, use 60_000 / 300_000.

# How often the cron scans for eligible records (ms). Default: 15s
REFUND_INTERVAL_MS=15000

# Grace period — how old a PAID record must be before it is eligible for
# refund. Exists to cover network delays in normal delivery. Default: 30s
REFUND_MIN_AGE_MS=30000
