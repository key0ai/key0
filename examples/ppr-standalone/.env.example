# Network: "testnet" (Base Sepolia) or "mainnet" (Base)
KEY0_NETWORK=testnet

# Your receive-only wallet address (0x-prefixed, 40 hex chars)
KEY0_WALLET_ADDRESS=0xYourWalletAddressHere

# Secret for signing access tokens (minimum 32 characters)
KEY0_ACCESS_TOKEN_SECRET=change-me-to-a-random-string-at-least-32-chars

# Gas wallet private key for self-contained on-chain settlement.
# When set, settlement is done directly via this wallet (no Coinbase facilitator needed).
# Omit to use the Coinbase x402 facilitator instead.
GAS_WALLET_PRIVATE_KEY=0xYourGasWalletPrivateKeyHere

# Optional: override the default RPC URL
# KEY0_RPC_URL=https://sepolia.base.org

# Redis connection URL (required for challenge store + double-spend prevention)
REDIS_URL=redis://localhost:6379

# Shared secret between the gateway and backend (backend returns 403 without it)
GATEWAY_SECRET=change-me-to-a-random-string

# Gateway port (the public-facing payment proxy)
GATEWAY_PORT=3000

# Public URL used in agent card and discovery responses
PUBLIC_URL=http://localhost:3000

# Backend service URL (where the gateway proxies paid requests)
BACKEND_URL=http://localhost:3001

# Backend port (only used by backend.ts)
BACKEND_PORT=3001
