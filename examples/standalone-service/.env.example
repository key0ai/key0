# Server Configuration
KEY0_PORT=3001
KEY0_NETWORK=testnet

# Security (Required: 32+ characters)
KEY0_ACCESS_TOKEN_SECRET=replace_this_with_a_secure_32_char_secret_key

# Backend Integration
BACKEND_API_URL=http://localhost:3000
# Shared secret for authenticating requests between Key0 and Backend
INTERNAL_AUTH_SECRET=super-secret-internal-key

# Auth Strategy (shared-secret | jwt)
AUTH_STRATEGY=shared-secret

# Redis (Required)
REDIS_URL=redis://localhost:6379

# Provider Information
AGENT_NAME="Key0 Service"
AGENT_DESCRIPTION="Payment-gated API access for AI agents"
KEY0_PUBLIC_URL=http://localhost:3001
PROVIDER_NAME="Example Corp"
PROVIDER_URL="https://example.com"
KEY0_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Product Configuration
PRODUCTS='[{"tierId":"basic","name":"Basic Access","description":"Basic API access","amount":"0.99","currency":"USDC","accessDurationSeconds":3600},{"tierId":"premium","name":"Premium Access","description":"Premium API access","amount":"4.99","currency":"USDC","accessDurationSeconds":86400}]'

# Gas Wallet (Optional: enable with USE_GAS_WALLET=true)
USE_GAS_WALLET=false
GAS_WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# RPC URL (Optional: Defaults to public RPCs)
KEY0_RPC_URL=
