# ──────────────────────────────────────────────────────────────────────────────
# Key0 Docker — Environment Variables
# Copy this file to .env and fill in the required values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# USDC-receiving wallet address (0x...)
KEY0_WALLET_ADDRESS=0xYourWalletAddressHere

# URL that Key0 POSTs to after a payment is verified.
# Receives IssueTokenParams merged with the matching plan.
# Response is passed through to the client as-is (see README for schema).
ISSUE_TOKEN_API=https://api.example.com/issue-token

# ── Network ───────────────────────────────────────────────────────────────────

# mainnet or testnet (Base Sepolia). Default: testnet
KEY0_NETWORK=testnet

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000

# Mount path for A2A endpoints. Default: /a2a
# BASE_PATH=/a2a

# ── Agent Card ────────────────────────────────────────────────────────────────

AGENT_NAME=Key0 Server
AGENT_DESCRIPTION=Payment-gated A2A endpoint
# Public URL of this server (used in agent card and resource endpoint URLs)
AGENT_URL=http://localhost:3000
PROVIDER_NAME=Key0
PROVIDER_URL=https://key0.ai

# ── Pricing Plans ─────────────────────────────────────────────────────────────

# JSON array of Plan objects. Any extra fields are forwarded to ISSUE_TOKEN_API.
# Default: single $0.10 basic plan with 1-hour access.
#
# PLANS='[
#   {"planId":"basic","unitAmount":"$0.10","description":"Basic API access."},
#   {"planId":"pro","unitAmount":"$1.00","description":"Pro API access (24h)."}
# ]'

# ── Challenge ─────────────────────────────────────────────────────────────────

# How long (seconds) a payment challenge stays valid. Default: 900 (15 min)
# CHALLENGE_TTL_SECONDS=900

# ── Token API Auth ────────────────────────────────────────────────────────────

# Auth strategy for ISSUE_TOKEN_API requests: none | shared-secret | jwt
# Default: none (no auth headers sent)
# BACKEND_AUTH_STRATEGY=none

# If set (with shared-secret or jwt strategy), adds Authorization: Bearer <secret>
# ISSUE_TOKEN_API_SECRET=your-shared-secret-here

# ── Storage (required) ────────────────────────────────────────────────────────

# Redis is mandatory — Key0 uses it for challenge state and double-spend prevention.
REDIS_URL=redis://redis:6379

# ── Settlement ────────────────────────────────────────────────────────────────

# If set, use gas wallet mode for payment settlement (self-contained, no facilitator needed).
# Leave empty to use the default facilitator URL from the network config.
# GAS_WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# ── Refund cron ───────────────────────────────────────────────────────────────

# Private key of KEY0_WALLET_ADDRESS — used to send USDC refunds back to payers
# when token issuance fails. Requires REDIS_URL (BullMQ) for multi-instance safety.
# KEY0_WALLET_PRIVATE_KEY=0xYourWalletPrivateKeyHere

# How often the cron scans for refund-eligible records (ms). Default: 60s
# REFUND_INTERVAL_MS=60000

# Grace period before a PAID record is eligible for refund (ms). Default: 5 min
# REFUND_MIN_AGE_MS=300000

# Max records to process per cron run. Default: 50
# REFUND_BATCH_SIZE=50

# ── Token Issuance ──────────────────────────────────────────────────────────

# Timeout for fetchResourceCredentials callback (ms). Default: 15s
# TOKEN_ISSUE_TIMEOUT_MS=15000

# Max retries for fetchResourceCredentials on failure. Default: 2
# TOKEN_ISSUE_RETRIES=2
